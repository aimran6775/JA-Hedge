# ============================================================
# JA Hedge — Environment Configuration
# Copy to .env and fill in values
# ============================================================

# ── Mode ──────────────────────────────────────────────────
# "demo" or "production" — controls which Kalshi URLs are used
JAHEDGE_MODE=demo

# ── Kalshi API Keys (injected at Phase 20) ────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi.pem

# ── Kalshi URLs (auto-selected by mode, override if needed)
# KALSHI_REST_BASE_URL=
# KALSHI_WS_BASE_URL=

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=jahedge
POSTGRES_PASSWORD=jahedge_dev_2026
POSTGRES_DB=jahedge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Risk Defaults ─────────────────────────────────────────
RISK_MAX_DAILY_LOSS=50.00
RISK_MAX_POSITION_SIZE=10
RISK_MAX_PORTFOLIO_EXPOSURE=500.00
KILL_SWITCH_ENABLED=true

# ── Strategy Defaults ─────────────────────────────────────
STRATEGY_MIN_CONFIDENCE=0.60
STRATEGY_MIN_EDGE=0.05
STRATEGY_KELLY_FRACTION=0.25
STRATEGY_SCAN_INTERVAL=30.0

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_READ_PER_SEC=20
RATE_LIMIT_WRITE_PER_SEC=10

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
